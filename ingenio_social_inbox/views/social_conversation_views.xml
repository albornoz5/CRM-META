<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List view (Inbox) ──────────────────────────────────────────── -->
    <record id="view_social_conversation_list" model="ir.ui.view">
        <field name="name">social.conversation.list</field>
        <field name="model">social.conversation</field>
        <field name="arch" type="xml">
            <list string="Conversaciones"
                  decoration-primary="unread == True"
                  decoration-muted="state == 'closed'"
                  decoration-success="state == 'converted'">
                <field name="platform" string="Plataforma" optional="show"/>
                <field name="sender_name" string="Remitente"/>
                <field name="account_id" string="Cuenta" optional="show"/>
                <field name="last_message" string="Último mensaje"/>
                <field name="last_message_date" string="Fecha"/>
                <field name="unread" string="Sin leer" optional="show"/>
                <field name="state" widget="badge"/>
                <field name="user_id" string="Vendedor" optional="show"/>
                <field name="lead_id" string="Lead" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ── Kanban view ────────────────────────────────────────────────── -->
    <record id="view_social_conversation_kanban" model="ir.ui.view">
        <field name="name">social.conversation.kanban</field>
        <field name="model">social.conversation</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="false">
                <field name="id"/>
                <field name="sender_name"/>
                <field name="platform"/>
                <field name="last_message"/>
                <field name="last_message_date"/>
                <field name="unread"/>
                <field name="state"/>
                <field name="lead_id"/>
                <field name="user_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click p-2">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <strong>
                                    <t t-esc="record.sender_name.value or record.id.value"/>
                                </strong>
                                <small class="text-muted">
                                    <t t-esc="record.last_message_date.value"/>
                                </small>
                            </div>
                            <div class="mb-1">
                                <span class="badge rounded-pill bg-secondary">
                                    <t t-esc="record.platform.value"/>
                                </span>
                                <t t-if="record.unread.raw_value">
                                    <span class="badge rounded-pill bg-primary ms-1">Nuevo</span>
                                </t>
                            </div>
                            <p class="text-muted small mb-1 o_text_overflow">
                                <t t-esc="record.last_message.value"/>
                            </p>
                            <t t-if="record.lead_id.raw_value">
                                <small class="text-success">
                                    ✓ Lead vinculado
                                </small>
                            </t>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ── Form view (Chat) ───────────────────────────────────────────── -->
    <record id="view_social_conversation_form" model="ir.ui.view">
        <field name="name">social.conversation.form</field>
        <field name="model">social.conversation</field>
        <field name="arch" type="xml">
            <form string="Conversación">
                <header>
                    <button name="action_mark_read" type="object"
                            string="Marcar leído"
                            invisible="not unread"/>
                    <button name="action_create_lead" type="object"
                            string="Crear Lead" class="btn-primary"
                            invisible="lead_id"/>
                    <button name="action_create_lead" type="object"
                            string="Ver Lead"
                            invisible="not lead_id"/>
                    <button name="action_close" type="object"
                            string="Cerrar"
                            invisible="state == 'closed'"/>
                    <button name="action_reopen" type="object"
                            string="Reabrir"
                            invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,open,converted,closed"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Conversación">
                            <field name="platform"/>
                            <field name="account_id"/>
                            <field name="sender_id" string="ID Remitente" readonly="1"/>
                            <field name="unread" string="Sin leer"/>
                        </group>
                        <group string="Gestión">
                            <field name="user_id"/>
                            <field name="partner_id"/>
                            <field name="lead_id" readonly="1"/>
                            <field name="message_count" string="Mensajes" readonly="1"/>
                        </group>
                    </group>

                    <separator string="Conversación"/>
                    <div class="si-chat-container">
                        <field name="messages_html" widget="html" readonly="1"/>
                    </div>

                    <separator string="Responder"/>
                    <group>
                        <field name="reply_text"
                               placeholder="Escribí tu respuesta aquí..."
                               invisible="state == 'closed'"/>
                    </group>
                    <div>
                        <button name="action_send_reply" type="object"
                                string="Enviar Respuesta" class="btn-primary"
                                invisible="state == 'closed'"/>
                    </div>

                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Search view ────────────────────────────────────────────────── -->
    <record id="view_social_conversation_search" model="ir.ui.view">
        <field name="name">social.conversation.search</field>
        <field name="model">social.conversation</field>
        <field name="arch" type="xml">
            <search string="Buscar conversaciones">
                <field name="sender_name" string="Remitente"/>
                <field name="last_message" string="Mensaje"/>
                <field name="account_id"/>
                <field name="user_id" string="Vendedor"/>
                <filter name="filter_unread" string="Sin leer" domain="[('unread', '=', True)]"/>
                <filter name="filter_new" string="Nuevos" domain="[('state', '=', 'new')]"/>
                <filter name="filter_open" string="Abiertos" domain="[('state', '=', 'open')]"/>
                <filter name="filter_converted" string="Convertidos" domain="[('state', '=', 'converted')]"/>
                <filter name="filter_closed" string="Cerrados" domain="[('state', '=', 'closed')]"/>
                <filter name="filter_facebook" string="Facebook" domain="[('platform', '=', 'facebook')]"/>
                <filter name="filter_instagram" string="Instagram" domain="[('platform', '=', 'instagram')]"/>
                <filter name="filter_my" string="Mis conversaciones" domain="[('user_id', '=', uid)]"/>
                <group string="Agrupar por">
                    <filter name="group_platform" string="Plataforma" context="{'group_by': 'platform'}"/>
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_account" string="Cuenta" context="{'group_by': 'account_id'}"/>
                    <filter name="group_user" string="Vendedor" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Actions ────────────────────────────────────────────────────── -->
    <record id="action_social_conversation" model="ir.actions.act_window">
        <field name="name">Social Inbox</field>
        <field name="res_model">social.conversation</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_filter_unread': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay conversaciones nuevas
            </p>
            <p>
                Los mensajes de Facebook e Instagram aparecerán aquí
                cuando configures las cuentas y el webhook de Meta.
            </p>
        </field>
    </record>

    <record id="action_social_conversation_all" model="ir.actions.act_window">
        <field name="name">Todas las Conversaciones</field>
        <field name="res_model">social.conversation</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</odoo>
